APP_NAME=nmbabudgam
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://nmbabudgam.in

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

DISTRICT_ID=5
DISTRICT_NAME="Budgam"

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@nmbabudgam.in"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Portal API Credentials ─────────────────────────────────────────────────────
# The external government portal this app syncs events to.
# Generate fresh credentials from the portal admin panel.
# Run quarterly: php artisan portal:check-credentials
PORTAL_URL=https://nashamuktjk.org/enterprise
PORTAL_EMAIL=
PORTAL_PASSWORD=
PORTAL_CREDENTIALS_LAST_ROTATED=

# ── Cron Security Token ────────────────────────────────────────────────────────
# Used to authenticate the web-cron endpoint at /nmba-cron.php?token=...
# Generate a new token: openssl rand -hex 32
# MUST match the token in Hostinger hPanel cron URL.
# See README.md > "Deployment Secrets" for full setup instructions.
CRON_TOKEN=

# ── Operational Alerting ───────────────────────────────────────────────────────
# Email address to receive sync backlog alerts from: php artisan sync:health-check
ADMIN_EMAIL=

# ── Sync Mode (Emergency Rollback Flag) ───────────────────────────────────────
# async = normal operation (dispatch to queue — default)
# sync  = bypass queue, call portal API synchronously per request
# See ROLLBACK.md for full rollback procedure.
SYNC_MODE=async
